{
  "manifest_version": 3,
  "name": "Conversation Optimizer for ChatGPT",
  "version": "1.0.0",
  "description": "Improve performance in long ChatGPT conversations by optimizing off-screen messages.",
  "permissions": ["storage"],
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}